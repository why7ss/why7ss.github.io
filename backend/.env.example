# Backend .env.example

# Database
MONGODB_URI=mongodb://localhost:27017/easygame

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server
PORT=5000
NODE_ENV=development

# File upload
MAX_FILE_SIZE=10485760

# Web Push Notifications (VAPID KEYS)
# Сгенерируйте с помощью: npm run generate-vapid
VAPID_PUBLIC_KEY=YOUR_PUBLIC_KEY_HERE
VAPID_PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE
VAPID_SUBJECT=mailto:admin@easygame.com

# Пример VAPID ключей (ВЫМЫШЛЕННЫЕ!):
# Не используйте на production!
# VAPID_PUBLIC_KEY=BEl62iUeJBIubNgTi5KPKHXWv52iUeJBIubNgTi5KPKHXWv52iUeJBIubNgTi5KPKHXWv52iUeJBIubNgTi5KPKHXWv52=
# VAPID_PRIVATE_KEY=yCEjsH2Yy5qXpZ0lqyCEjsH2Yy5qXpZ0lqyCEjsH2Yy5qXpZ0lq

